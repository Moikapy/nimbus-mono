{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "types": ["@opentui/solid", "@types/node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
