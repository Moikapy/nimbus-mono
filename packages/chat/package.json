{
  "name": "nimbus-chat",
  "version": "0.1.0",
  "description": "T3.chat-like PWA for Nimbus agents. Next.js 15 + Cloudflare Workers.",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "cf:build": "opennextjs-cloudflare build",
    "cf:deploy": "opennextjs-cloudflare build && wrangler deploy",
    "cf:preview": "opennextjs-cloudflare build && wrangler dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.0",
    "@cloudflare/kv-asset-handler": "^0.4.2",
    "ai": "^6.0.0",
    "lucide-react": "^0.500.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250414.0",
    "@opennextjs/cloudflare": "^1.19.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5",
    "wrangler": "^4.84.1"
  }
