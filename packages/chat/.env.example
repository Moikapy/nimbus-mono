/**
 * 0xNIMBUS — Environment Variables
 *
 * Copy to .env and fill in your real keys.
 * No secrets committed to git.
 */

# ─── Agent (Worker) ───
# Default: workers.dev domain. Change after adding custom domain.
NEXT_PUBLIC_AGENT_URL=https://nimbus-agent.workers.dev

# ─── Clerk Auth (needed for Pro/Premier upgrades) ───
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── Stripe (needed for paid tiers) ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIER=price_...

# ─── Stripe Domain ───
# If you add chat.moikapy.dev later, update this:
# NEXT_PUBLIC_SITE_URL=https://chat.moikapy.dev
